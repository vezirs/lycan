generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String?   // nullable if using external auth
  name        String?
  role        String    @default("owner")
  isActive    Boolean   @default(true)
  organizations OrganizationUser[]
  widgets     Widget[]  @relation("ownerWidgets")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  ownerId   String
  owner     User      @relation(fields: [ownerId], references: [id])
  members   OrganizationUser[]
  widgets   Widget[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model OrganizationUser {
  id             String @id @default(uuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  role           String       @default("member")
  createdAt      DateTime     @default(now())
  @@unique([organizationId, userId])
}

model Widget {
  id          String   @id @default(uuid())
  name        String?
  slug        String?  @unique
  ownerId     String
  owner       User     @relation("ownerWidgets", fields: [ownerId], references: [id])
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id])
  settings    Json     @default("{}")
  scriptToken String?  // optional secret for signed requests
  isEnabled   Boolean  @default(true)
  visitors    Visitor[]
  conversations Conversation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Visitor {
  id                String   @id @default(uuid())
  widgetId          String
  widget            Widget   @relation(fields: [widgetId], references: [id])
  visitorIdentifier String?  // cookie or client-generated id
  meta              Json?
  createdAt         DateTime @default(now())
  lastSeenAt        DateTime?
  conversations     Conversation[]
}

model Conversation {
  id           String    @id @default(uuid())
  widgetId     String
  widget       Widget    @relation(fields: [widgetId], references: [id])
  visitorId    String?
  visitor      Visitor?  @relation(fields: [visitorId], references: [id])
  title        String?
  status       String    @default("open")
  assigneeId   String?
  assignee     User?     @relation(fields: [assigneeId], references: [id])
  unreadCount  Int       @default(0)
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderType     String   // 'visitor' | 'agent' | 'system' | 'bot'
  senderId       String?  // user id or visitor id
  body           String?
  content        Json?
  delivered      Boolean  @default(false)
  read           Boolean  @default(false)
  attachments    Attachment[]
  createdAt      DateTime @default(now())
}

model Attachment {
  id         String   @id @default(uuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id])
  url        String
  filename   String?
  contentType String?
  size       Int?
  createdAt  DateTime @default(now())
}

model AgentSession {
  id         String   @id @default(uuid())
  userId     String?
  socketId   String   @unique
  state      String   @default("connected")
  createdAt  DateTime @default(now())
  lastSeenAt DateTime?
}

model AuditEvent {
  id        String   @id @default(uuid())
  type      String
  payload   Json
  createdAt DateTime @default(now())
}
